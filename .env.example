# ============================================================
# repengine — Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# .env is already listed in .gitignore.
# ============================================================


# ============================================================
# Database
# ============================================================

# Full PostgreSQL connection string used by the Go API.
# Format: postgres://<user>:<password>@<host>:<port>/<dbname>
# In docker compose, the host is the service name ("db").
DATABASE_URL=postgres://rep:changeme@db:5432/repengine

# Individual credentials used by the postgres container itself
# and by backup/restore scripts.
POSTGRES_USER=rep
POSTGRES_PASSWORD=changeme
POSTGRES_DB=repengine


# ============================================================
# Authentication
# ============================================================

# JWT signing secret. Must be a long random string.
# Generate one with: openssl rand -hex 32
# Minimum recommended length: 32 characters.
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars


# ============================================================
# Application
# ============================================================

# Runtime environment name. Controls logging behaviour and
# feature flags. Values: production | staging | development
APP_ENV=development

# Log verbosity. Values: debug | info | warn | error
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins.
# Example (production): https://app.example.com
# Example (dev):        http://localhost:3000
CORS_ORIGINS=http://localhost:3000


# ============================================================
# Docker / Deploy
# ============================================================

# Semantic version tag applied to built Docker images.
# Used by deploy.sh and docker-compose.prod.yml image references.
# Example: 1.2.3  or  v1.2.3
VERSION=dev

# Docker registry prefix for image names.
# Example: ghcr.io/momarinho
# The full image name becomes: ${REGISTRY}/repengine-api:${VERSION}
REGISTRY=ghcr.io/momarinho


# ============================================================
# Observability
# ============================================================

# Password for the Grafana admin user.
# Change before first run in any shared environment.
GRAFANA_PASSWORD=changeme


# ============================================================
# Backup
# ============================================================

# Local filesystem directory where pg_dump backups are stored.
# Created automatically if it does not exist.
# Default (if unset): ./backups
BACKUP_DIR=./backups

# Optional: AWS S3 bucket name for off-site backup storage.
# If set, backup.sh uploads each dump to s3://<bucket>/backups/
# Leave empty to disable S3 upload.
# Requires the aws CLI to be installed and configured.
BACKUP_S3_BUCKET=


# ============================================================
# Staging only — pgAdmin web UI
# ============================================================

# pgAdmin login credentials (only used in docker-compose.staging.yml).
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme
